# ── Rust / Soroban ────────────────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock          # remove this line if you want to lock deps (recommended for apps)

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
.vite/
*.local

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example        # keep the example template

# ── Stellar / Soroban CLI ─────────────────────────────────────────────────────
.soroban/
identity/
*.wasm              # compiled contract binaries (regenerate with `soroban contract build`)

# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
